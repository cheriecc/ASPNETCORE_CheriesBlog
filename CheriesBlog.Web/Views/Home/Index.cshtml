@model IEnumerable<CheriesBlog.Domain.Models.Post>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Home";
}


<header class="masthead" style="background-image: url('/img/bg-img-home.jpg');">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 col-md-10 mx-auto">
                <div class="page-heading">
                    <h1>Cheire's Blog</h1>
                    <span class="subheading">A collection of some interesting moments.</span>
                </div>
            </div>
        </div>
    </div>
</header>


<div class="container">
    <div class="row">
        <div class="col-lg-8 col-md-10 mx-auto">

            @if (Model == null || !Model.Any())
            {
                <p>No posts available.</p>
            }
            else
            {
                <h1>All Posts</h1>
                @foreach (var post in Model)
                {
                    <div class="post preview">
                        <a style="text-decoration:none" href="/Post/Details/@post.Id">
                            <h2 class="post-title">@post.Title</h2>
                        </a>
                        <h3 class="post-subtitle">@post.SubTitle</h3>
                        <p class="post-reference">Posted by @(post.Author?.FirstName ?? "Unknown Author") on
                            @post.CreatedAt.ToString("MMMM dd, yyyy")
                            @if (User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == post.UserId)
                            {
                                @* <a class="delete-link" style="--bs-link-opacity: .5" href="/Post/DeletePost/@post.Id">Delete post</a> *@
                                <div class="clearfix">
                                    <form method="post" asp-controller="Post" asp-action="DeletePost" class="delete-link" style="--bs-link-opacity: .5">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@post.Id" />
                                        <button type="submit" class="btn btn-danger float-right" 
                                                onclick="return confirm('Are you sure you want to delete this post?')">
                                            Delete Post
                                        </button>
                                    </form>
                                </div>
                            }
                        </p>
                        <hr>
                    </div>
                }
            }
            <div class="clearfix">
                <a class="btn btn-primary float-right" href="/Post/AddPost">Create a New Post</a>
            </div>
        </div>
    </div>
</div>