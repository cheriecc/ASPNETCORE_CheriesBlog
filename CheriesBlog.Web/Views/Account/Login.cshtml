@model CheriesBlog.Domain.Dtos.UserLoginDto
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Login";
}
<header class="masthead" style="background-image: url('/img/bg-img-login.jpg');">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 col-md-10 mx-auto">
                <div class="page-heading">
                    <h1>Log in</h1>
                    <span class="subheading">Welcome back!</span>
                </div>
            </div>
        </div>
    </div>
</header>


@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @Html.ValidationSummary(false, "", new { @class = "text-danger" })
    </div>
}

<form method="post" asp-action="Login" asp-controller="Account">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label for="username">Username</label>
        @* <p id="flashes_msg" class="error-msg">@Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger" })</p> *@
        @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
    </div>
    <div class="form-group">
        <label for="password">Password</label>
        @* <p id="flashes_msg" class="error-msg">@Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })</p> *@
        @Html.PasswordFor(m => m.Password, new { @class = "form-control" })
    </div>
    <button type="submit" class="btn btn-primary">Login</button>
    <a href="/Account/Register" class="btn btn-primary">Register</a>
</form>