@model CheriesBlog.Domain.Dtos.PostToAddDto
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "New Post";
}


<header class="masthead" style="background-image: url('/img/bg-img-edit.jpg');">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 col-md-10 mx-auto">
                <div class="page-heading">
                    <h1>@ViewData["Title"]</h1>
                </div>
            </div>
        </div>
    </div>
</header>

<!--write new post or edit post-->
<div class="container self-intro">
    <div class="row">
        <div class="col-lg-8 col-md-10 mx-auto">

            <form method="post" asp-action="AddPost">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label for="title">Title</label>
                    @Html.TextBoxFor(m => m.Title, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
                </div>
                <div class="form-group">
                    <label for="subTitle">SubTitle</label>
                    @Html.TextBoxFor(m => m.SubTitle, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.SubTitle, "", new { @class = "text-danger" })
                </div>
                <div class="form-group">
                    <label for="imageUrl">Image URL</label>
                    @Html.TextBoxFor(m => m.ImageUrl, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.ImageUrl, "", new { @class = "text-danger" })
                </div>
                <div class="form-group">
                    <label for="content">Content</label>
                    <textarea id="content" name="Content" class="form-control">@Model.Content</textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                    @* @Html.TextAreaFor(m => m.Content, new { @class = "form-control" }) *@
                    @* @Html.ValidationMessageFor(m => m.Content, "", new { @class = "text-danger" }) *@
                </div>
                <button type="submit" class="btn btn-primary">Create</button>
                <a href="/" class="btn btn-primary">Exit</a>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        tinymce.init({
            selector: 'textarea#content',
            license_key: 'gpl'
        });
    </script>
}